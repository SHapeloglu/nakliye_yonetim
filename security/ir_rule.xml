<odoo>
    <!-- SAHA KURALLARI -->
    <!-- Formen sadece atandığı sahaları görür -->
    <!-- Kalıcı atama: saha.formen_ids içinde -->
    <!-- Geçici atama: Faz sonunda eklenecek -->
    <record id="rule_saha_formen" model="ir.rule">
        <field name="name">Saha — Formen Erişimi</field>
        <field name="model_id" ref="nakliye_yonetim.model_nakliye_saha"/>
        <field name="groups" eval="[(4, ref('group_nakliye_formen'))]"/>
        <field name="domain_force">
            [('formen_ids', 'in', [user.id])]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Şantiye muhasebecisi sadece kendi şantiyesindeki sahaları görür -->
    <record id="rule_saha_santiye_muhasebe" model="ir.rule">
        <field name="name">Saha — Şantiye Muhasebecisi Erişimi</field>
        <!-- nakliye_yonetim. prefix zorunlu — aynı modül içinde bile -->
        <field name="model_id" ref="nakliye_yonetim.model_nakliye_saha"/>
        <field name="groups" eval="[(4, ref('group_nakliye_santiye_muhasebe'))]"/>
        <field name="domain_force">
            [('santiye_id.muhasebeci_ids', 'in', [user.id])]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

