<odoo>
    <record id="view_hr_employee_form_nakliye" model="ir.ui.view">
        <field name="name">hr.employee.form.nakliye</field>
        <field name="model">hr.employee</field>
        <!-- Odoo'nun mevcut çalışan form view'ına ekleme yapıyoruz -->
        <!-- inherit_id → hangi view'ı extend ettiğimizi belirtir -->
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- position="inside" → mevcut notebook'un içine yeni sekme ekle -->
            <notebook position="inside">
                <page string="Şantiye Bilgileri">
                    <!-- başlıksız group → iki sütun düzen -->
                    <group>
                        <field name="calisma_tipi"/>
                        <field name="odoo_user_id"/>
                        <!-- readonly="1" → kullanıcı değiştiremez, sistem hesaplar -->
                        <field name="aktif_santiye_id" readonly="1"/>
                    </group>
                    <!-- string="..." → bölüm başlığı ekler -->
                    <group string="Şantiye Atama Geçmişi">
                        <field name="santiye_atama_ids">
                            <!-- One2many alanı liste olarak gösteriliyor -->
                            <list>
                                <field name="santiye_id"/>
                                <field name="baslangic_tarihi"/>
                                <field name="bitis_tarihi"/>
                                <field name="gecis_nedeni"/>
                                <field name="aktif"/>
                                <field name="notlar"/>
                            </list>
                        </field>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>