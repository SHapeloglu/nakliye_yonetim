<odoo>
    <!-- Form View -->
    <record id="view_santiye_form" model="ir.ui.view">
        <field name="name">nakliye.santiye.form</field>
        <field name="model">nakliye.santiye</field>
        <field name="arch" type="xml">
            <form string="Şantiye">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="kod"/>
                        <field name="aktif"/>
                    </group>
                    <group string="Muhasebeciler">
                        <field name="muhasebeci_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
                <!-- mail.thread sayesinde chatter otomatik gelir -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_santiye_list" model="ir.ui.view">
        <field name="name">nakliye.santiye.list</field>
        <field name="model">nakliye.santiye</field>
        <field name="arch" type="xml">
            <list string="Şantiyeler">
                <field name="name"/>
                <field name="kod"/>
                <field name="aktif"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_santiye" model="ir.actions.act_window">
        <field name="name">Şantiyeler</field>
        <field name="res_model">nakliye.santiye</field>
        <field name="view_mode">list,form</field>
		 <field name="path">nakliye-santiye</field>

    </record>

  <menuitem id="menu_nakliye_root"
          name="Nakliye Yönetim"
          sequence="10"
          groups="nakliye_yonetim.group_nakliye_formen"/>


<menuitem id="menu_tanimlamalar"
          name="Tanımlamalar"
          parent="menu_nakliye_root"
          sequence="10"/>

<menuitem id="menu_santiye"
          name="Şantiyeler"
          parent="menu_tanimlamalar"
          action="action_santiye"
          sequence="10"/>
</odoo>