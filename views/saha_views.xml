<odoo>
    <!-- Form View -->
    <record id="view_saha_form" model="ir.ui.view">
        <field name="name">nakliye.saha.form</field>
        <field name="model">nakliye.saha</field>
        <field name="arch" type="xml">
            <form string="Saha">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="santiye_id"/>
                        <field name="aktif"/>
                    </group>
                    <group string="Konum">
                        <field name="partner_latitude"/>
                        <field name="partner_longitude"/>
                    </group>
                    <group string="Formenler">
                        <field name="formen_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_saha_list" model="ir.ui.view">
        <field name="name">nakliye.saha.list</field>
        <field name="model">nakliye.saha</field>
        <field name="arch" type="xml">
            <list string="Sahalar">
                <field name="name"/>
                <field name="santiye_id"/>
                <field name="aktif"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_saha" model="ir.actions.act_window">
        <field name="name">Sahalar</field>
        <field name="res_model">nakliye.saha</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_saha"
              name="Sahalar"
              parent="menu_tanimlamalar"
              action="action_saha"
              sequence="20"/>
</odoo>