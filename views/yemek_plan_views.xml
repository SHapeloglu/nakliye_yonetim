<odoo>
    <!-- Form View -->
    <record id="view_yemek_plan_form" model="ir.ui.view">
        <field name="name">nakliye.yemek.plan.form</field>
        <field name="model">nakliye.yemek.plan</field>
        <field name="arch" type="xml">
            <form string="Yemek Planı">
                <header>
                    <!-- Dublike butonu — yeni plan oluşturmak için -->
                    <button name="action_dublike" string="Planı Güncelle (Dublike Et)"
                            type="object" class="btn-warning"
                            invisible="not aktif"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="santiye_id"/>
                            <field name="aktif"/>
                        </group>
                        <group>
                            <field name="baslangic_tarihi"/>
                            <field name="bitis_tarihi"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Plan Satırları">
                            <field name="satir_ids">
                            <tree editable="bottom">
                            <field name="satir_tipi"/>
                            <!-- Firma içi işçi -->
                            <field name="isci_id"
                            invisible="satir_tipi != 'firma_isci'"/>
                            <!-- Personel -->
                            <field name="personel_id"
                            invisible="satir_tipi != 'personel'"/>
                            <!-- Taşeron nakliye — önce firma, sonra araç, sonra şoför -->
                            <field name="nakliye_firma_id"
                            invisible="satir_tipi != 'taseron_nakliye'"/>
                            <field name="arac_id"
                            invisible="satir_tipi != 'taseron_nakliye'"/>
                            <field name="sofor_adi"
                            invisible="satir_tipi != 'taseron_nakliye'"
                            readonly="1"/>
                            <!-- Taşeron işçi — önce firma, sonra işçi -->
                            <field name="taseron_firma_id"
                            invisible="satir_tipi != 'taseron_isci'"/>
                            <field name="taseron_isci_id"
                            invisible="satir_tipi != 'taseron_isci'"/>
                            <field name="adet"/>
                            <field name="notlar"/>
                            </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_yemek_plan_list" model="ir.ui.view">
        <field name="name">nakliye.yemek.plan.list</field>
        <field name="model">nakliye.yemek.plan</field>
        <field name="arch" type="xml">
            <tree string="Yemek Planları">
                <field name="name"/>
                <field name="santiye_id"/>
                <field name="baslangic_tarihi"/>
                <field name="bitis_tarihi"/>
                <field name="aktif"/>
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_yemek_plan" model="ir.actions.act_window">
        <field name="name">Yemek Planları</field>
        <field name="res_model">nakliye.yemek.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menü — Tanımlamalar altına eklenir -->
    <menuitem id="menu_yemek_plan"
              name="Yemek Planları"
              parent="menu_tanimlamalar"
              action="action_yemek_plan"
              sequence="40"
              groups="nakliye_yonetim.group_nakliye_santiye_muhasebe"/>
</odoo>